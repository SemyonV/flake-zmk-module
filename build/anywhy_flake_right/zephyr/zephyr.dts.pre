# 0 "<command-line>" 2
# 1 "/zmk/zmk/app/boards/nicekeyboards/nice_nano/nice_nano_nrf52840_zmk_2_0_0.overlay" 1






/ {
    chosen {
        zmk,battery = &vbatt;
    };


    EXT_POWER {
        compatible = "zmk,ext-power-generic";
        control-gpios = <&gpio0 13 (0 << 0)>;
        init-delay-ms = <50>;
    };

    vbatt: vbatt {
        compatible = "zmk,battery-nrf-vddh";
    };
};

&reg0 {
    status = "okay";
};

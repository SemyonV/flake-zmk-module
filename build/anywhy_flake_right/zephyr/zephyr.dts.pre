    col-gpios
        = <&pro_micro 14 (0 << 0)>
        , <&pro_micro 15 (0 << 0)>
        , <&pro_micro 18 (0 << 0)>
        , <&pro_micro 19 (0 << 0)>
        , <&pro_micro 20 (0 << 0)>
        , <&pro_micro 21 (0 << 0)>
        ;

    row-gpios
        = <&pro_micro 16 ((0 << 0) | (1 << 5))>
        , <&pro_micro 10 ((0 << 0) | (1 << 5))>
        , <&pro_micro 9 ((0 << 0) | (1 << 5))>
        , <&pro_micro 8 ((0 << 0) | (1 << 5))>
        , <&pro_micro 7 ((0 << 0) | (1 << 5))>
        ;
};
